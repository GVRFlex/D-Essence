---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | D-Essence Wellness">
  <section class="min-h-[80vh] flex flex-col items-center justify-center text-center px-6 py-24 bg-neutral-950">
    <img 
      src="/LOGO_W.webp" 
      alt="D-Essence Wellness Logo" 
      class="w-40 mb-10 opacity-90"
      loading="lazy"
    />
    <h1 class="text-4xl md:text-5xl font-semibold text-white mb-4 tracking-tight">
      Page Not Found
    </h1>
    <p class="text-neutral-400 text-lg max-w-md mb-10">
      The page you’re looking for doesn’t exist or may have been moved.
    </p>
    <a 
      href="/" 
      class="inline-flex items-center px-6 py-3 rounded-full border border-white/20 text-white/90 hover:text-white hover:border-white/40 transition-all duration-300 text-sm md:text-base"
    >
      Go Back Home
    </a>
  </section>
</BaseLayout>
