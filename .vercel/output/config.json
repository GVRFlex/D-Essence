{
	"version": 3,
	"routes": [
		{
			"src": "^/\\.well-known(?:/.*)?$"
		},
		{
			"src": "^/((?:[^/]+/)*[^/\\.]+)$",
			"headers": {
				"Location": "/$1/"
			},
			"status": 308
		},
		{
			"src": "^/((?:[^/]+/)*[^/]+\\.\\w+)/$",
			"headers": {
				"Location": "/$1"
			},
			"status": 308
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
